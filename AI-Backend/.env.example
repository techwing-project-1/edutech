# ==========================================
# CurriculaMind AI Backend Configuration
# ==========================================

# ------------------------------------------
# Project Information
# ------------------------------------------
# Name of the project, used in Swagger UI and logs
PROJECT_NAME="CurriculaMind AI Backend"
# Current API version
VERSION="0.1.0"
# Running environment (e.g., development, staging, production)
ENVIRONMENT="development"

# ------------------------------------------
# Logging
# ------------------------------------------
# Sets the centralized application logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL="INFO"

# ------------------------------------------
# Primary LLM Provider: Google Gemini
# ------------------------------------------
# Google Gemini API key. This is the primary LLM for the application.
GEMINI_API_KEY="your_gemini_api_key_here"
 
# ------------------------------------------
# Fallback LLM Provider: OpenRouter
# ------------------------------------------
# OpenRouter API key. This is used automatically if the primary provider fails.
OPENROUTER_API_KEY="your_openrouter_api_key_here"
# The specific model to use via OpenRouter for fallback requests.
OPENROUTER_MODEL="qwen/qwen3-8b:free"

# ------------------------------------------
# Embedding Model Configuration
# ------------------------------------------
# The specific sentence-transformers model utilized for generating vector embeddings locally.
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# ------------------------------------------
# Production Vector Database: Amazon OpenSearch
# ------------------------------------------
# Secure credentials for Amazon OpenSearch connection.
# Must be configured before running the application.
OPENSEARCH_ENDPOINT=""
OPENSEARCH_USERNAME=""
OPENSEARCH_PASSWORD=""
AWS_REGION="ap-south-1"
OPENSEARCH_INDEX="curriculamindrag"

# ------------------------------------------
# LLM Request & Retry Configuration
# ------------------------------------------
# Maximum time in seconds to wait for an LLM response before throwing a Timeout error.
LLM_TIMEOUT="30"
# Maximum number of retry attempts for an LLM request before failing over to the fallback provider.
LLM_MAX_RETRIES="3"
